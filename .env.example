APP_NAME="Network Desk"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:3009

# Production (Laravel Cloud):
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://complaint-desk-main-m4onjc.laravel.cloud
# SESSION_SECURE_COOKIE=true
# LOG_STACK=stderr

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=network_desk
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=525600
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# SESSION_SECURE_COOKIE=true   # auto-enabled when APP_URL is https

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
MEDIA_DISK=public

# Laravel Cloud: attach a public bucket named "public" to inject AWS_* automatically.
# Locally, files use storage/app/public (run php artisan storage:link).
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=auto
# AWS_BUCKET=
# AWS_ENDPOINT=
# AWS_URL=
# AWS_USE_PATH_STYLE_ENDPOINT=false

QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"



VITE_APP_NAME="${APP_NAME}"

CENTRAL_URL=http://127.0.0.1:8000
CLIENT_ID=
CLIENT_SECRET=
REDIRECT_URI=http://127.0.0.1:3009/auth/callback

# Local development without central SSO (requires empty CLIENT_ID):
# LOCAL_DEV_AUTH=true
# DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite
# QUEUE_CONNECTION=sync
